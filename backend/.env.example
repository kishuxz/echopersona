# AI Services (required in live mode)
DEEPGRAM_API_KEY=your_deepgram_key
GROQ_API_KEY=your_groq_key
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=your_default_voice_id

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # backend only — never expose to frontend
SUPABASE_ANON_KEY=your_anon_key

# D-ID video avatars (optional — gracefully disabled if absent)
DID_API_KEY=your_did_api_key
DID_DEFAULT_SOURCE_URL=

# Simli real-time lip-sync avatar (optional — gracefully disabled if absent)
SIMLI_API_KEY=

# Redis (optional — used for caching; falls back to in-memory)
# Local:   redis://localhost:6379
# Upstash: rediss://default:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379

# App
ENVIRONMENT=development
MAX_CONCURRENT_SESSIONS=100
# Set to true to bypass all external APIs (Groq, ElevenLabs, Deepgram) with in-process stubs.
# Automatically enabled when API keys are absent; set explicitly to force mock mode in CI.
MOCK_MODE=false
# Comma-separated allowed origins; in production lock to exact Vercel URL
CORS_ORIGINS=http://localhost:5173

# Optional: self-hosted vLLM for sub-100ms LLM latency
VLLM_BASE_URL=
USE_VLLM=false

# Optional: Cartesia TTS
TTS_PROVIDER=elevenlabs
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
