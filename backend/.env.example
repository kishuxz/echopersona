# AI Services (required in live mode)
DEEPGRAM_API_KEY=your_deepgram_key
GROQ_API_KEY=your_groq_key
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=your_default_voice_id

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # backend only — never expose to frontend
SUPABASE_ANON_KEY=your_anon_key

# D-ID video avatars (optional — gracefully disabled if absent)
DID_API_KEY=your_did_api_key
DID_DEFAULT_SOURCE_URL=
# Public base URL used to build audio file URLs for D-ID lip-sync
PUBLIC_BASE_URL=https://kishoreai.online

# Simli real-time lip-sync avatar (optional — gracefully disabled if absent)
SIMLI_API_KEY=

# Tavus video avatar (optional — required for video chat mode)
# Get your API key at app.tavus.io
# replica_id is stored per-persona in the database (set via admin or persona creation flow)
TAVUS_API_KEY=

# Redis (optional — used for caching; falls back to in-memory)
# Local:   redis://localhost:6379
# Upstash: rediss://default:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379

# App
ENVIRONMENT=development
MAX_CONCURRENT_SESSIONS=100
# Set to true to bypass all external APIs (Groq, ElevenLabs, Deepgram) with in-process stubs.
# Automatically enabled when API keys are absent; set explicitly to force mock mode in CI.
MOCK_MODE=false
# Comma-separated allowed origins; in production set to https://kishoreai.online
CORS_ORIGINS=http://localhost:5173

# Optional: self-hosted vLLM for sub-100ms LLM latency
VLLM_BASE_URL=
USE_VLLM=false

# Optional: Cartesia TTS
TTS_PROVIDER=elevenlabs
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# Stripe billing (required for checkout and webhook)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
STRIPE_PRICE_CREATOR_MONTHLY=price_your_creator_monthly_price_id
STRIPE_PRICE_LEGACY_MONTHLY=price_your_legacy_monthly_price_id
# Override in production:
#   FRONTEND_BILLING_SUCCESS_URL=https://kishoreai.online/billing/success
#   FRONTEND_BILLING_CANCEL_URL=https://kishoreai.online/billing/cancel
FRONTEND_BILLING_SUCCESS_URL=http://localhost:5173/billing/success
FRONTEND_BILLING_CANCEL_URL=http://localhost:5173/billing/cancel

# Email (Resend — required for invite and readiness notification emails)
# Get your API key at resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_ADDRESS=noreply@kishoreai.online
