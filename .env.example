# AI Services
DEEPGRAM_API_KEY=your_deepgram_key_here
GROQ_API_KEY=your_groq_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=your_default_voice_id_here

# Redis
# Local dev:  redis://localhost:6379
# Docker:     redis://redis:6379  (overridden automatically by docker-compose)
REDIS_URL=redis://localhost:6379

# App
ENVIRONMENT=development
MAX_CONCURRENT_SESSIONS=100
# Local dev:  http://localhost:5173
# Docker:     http://localhost  (overridden automatically by docker-compose)
CORS_ORIGINS=http://localhost:5173

# Optional: self-hosted vLLM (set USE_VLLM=true and provide base URL)
VLLM_BASE_URL=
USE_VLLM=false

# Optional: Cartesia TTS (lower latency than ElevenLabs)
TTS_PROVIDER=elevenlabs
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
