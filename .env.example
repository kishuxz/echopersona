# ==============================================================================
# Root .env — used by Docker Compose for backend, worker, and frontend build.
# Copy: cp .env.example .env  then fill in real values.
# Never commit the real .env — it is gitignored.
# ==============================================================================

# --- Supabase (required) -------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
# Backend only — never expose to the frontend or commit to git
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- AI services ---------------------------------------------------------------
GROQ_API_KEY=your_groq_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=your_default_voice_id_here
# Optional: Deepgram STT
DEEPGRAM_API_KEY=

# --- App -----------------------------------------------------------------------
ENVIRONMENT=production
MAX_CONCURRENT_SESSIONS=100
# Comma-separated; Docker Compose overrides this via the environment: block.
# Set to https://kishoreai.online for production; http://localhost:5173 for local non-Docker.
CORS_ORIGINS=https://kishoreai.online
# Public base URL used to build D-ID audio file URLs
PUBLIC_BASE_URL=https://kishoreai.online

# --- Frontend build args (baked into the JS bundle at build time) --------------
# Docker Compose defaults to production values (kishoreai.online).
# Override here for local dev with Docker:
#   VITE_API_BASE_URL=http://localhost:8000
#   VITE_WS_BASE_URL=ws://localhost:8000
VITE_API_BASE_URL=https://kishoreai.online
VITE_WS_BASE_URL=wss://kishoreai.online

# --- Redis ---------------------------------------------------------------------
# Docker Compose always overrides this to redis://redis:6379 via environment:.
# Set redis://localhost:6379 for local non-Docker development.
REDIS_URL=redis://localhost:6379

# --- Stripe billing (required for billing features) ----------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
STRIPE_PRICE_CREATOR_MONTHLY=price_your_creator_monthly_price_id
STRIPE_PRICE_LEGACY_MONTHLY=price_your_legacy_monthly_price_id
FRONTEND_BILLING_SUCCESS_URL=https://kishoreai.online/billing/success
FRONTEND_BILLING_CANCEL_URL=https://kishoreai.online/billing/cancel

# --- Optional media APIs -------------------------------------------------------
TTS_PROVIDER=elevenlabs
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
DID_API_KEY=
DID_DEFAULT_SOURCE_URL=
SIMLI_API_KEY=

# --- Optional: self-hosted vLLM ------------------------------------------------
VLLM_BASE_URL=
USE_VLLM=false

# --- Dev / CI ------------------------------------------------------------------
# Set true to bypass all external APIs (Groq, ElevenLabs, Deepgram) with stubs.
# Automatically enabled when API keys are absent; set explicitly to force in CI.
MOCK_MODE=false
